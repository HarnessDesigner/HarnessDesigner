        ('pjt_bundles', pjt_bundles),
        ('pjt_seals', pjt_seals),
        ('pjt_boots', pjt_boots),
        ('pjt_covers', pjt_covers),
        ('pjt_cpa_locks', pjt_cpa_locks),
        ('pjt_tpa_locks', pjt_tpa_locks),
        ('pjt_splices', pjt_splices),
